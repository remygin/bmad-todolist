{
  "repository_type": "multi-part",
  "parts": [
    {
      "part_id": "frontend",
      "project_type_id": "web",
      "display_name": "Frontend (React/Vite)",
      "root_path": "frontend",
      "entry_points": ["frontend/src/main.tsx"],
      "architecture_doc": "architecture-frontend.md"
    },
    {
      "part_id": "backend",
      "project_type_id": "backend",
      "display_name": "Backend (Spring Boot)",
      "root_path": "backend",
      "entry_points": ["backend/src/main/java/com/bmad/todolist/TodolistApplication.java"],
      "architecture_doc": "architecture-backend.md"
    },
    {
      "part_id": "autotests",
      "project_type_id": "library",
      "display_name": "Autotests (Selenide + Rest Assured)",
      "root_path": "autotests",
      "entry_points": ["autotests/pom.xml"],
      "architecture_doc": "architecture-autotests.md"
    }
  ],
  "integration_points": [
    {
      "from": "frontend",
      "to": "backend",
      "type": "REST API",
      "details": "JSON over /api with Bearer JWT; Vite/nginx proxy"
    },
    {
      "from": "backend",
      "to": "postgresql",
      "type": "JDBC/JPA",
      "details": "Flyway migrations V1–V2"
    },
    {
      "from": "autotests",
      "to": "backend",
      "type": "HTTP (Rest Assured)",
      "details": "Direct api.baseUrl (default http://localhost:8081); smoke: /actuator/health, /api/auth/login"
    },
    {
      "from": "autotests",
      "to": "frontend",
      "type": "Browser (Selenide)",
      "details": "ui.baseUrl (default http://localhost:5173); smoke: /login form"
    }
  ]
}
