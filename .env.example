# Environment example — copy to `.env` and adjust values.
# Do not commit real secrets.

POSTGRES_DB=todolist
POSTGRES_USER=todolist
POSTGRES_PASSWORD=todolist
POSTGRES_PORT=5432

DATABASE_URL=jdbc:postgresql://db:5432/todolist
DATABASE_USERNAME=todolist
DATABASE_PASSWORD=todolist

JWT_SECRET=change-me-to-a-long-random-secret-key-at-least-256-bits-long
JWT_EXPIRATION_MS=3600000

ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

BACKEND_PORT=8080
FRONTEND_PORT=5173
